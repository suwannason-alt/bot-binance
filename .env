# =============================================================================
#  BTCUSDT Futures Trading Bot — Live Configuration
#  All values here override config.py defaults.
#  Proven backtest result (RISK_PERCENT=8%, WFO):  $1k → $32k, CAGR +101%/yr
# =============================================================================


# =============================================================================
#  [1] ENVIRONMENT & CREDENTIALS
# =============================================================================

ENV=production

# Set PAPER_TRADING=false ONLY after you have verified paper mode for 24-48h.
PAPER_TRADING=true

BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here


# =============================================================================
#  [2] SYMBOL & LEVERAGE
# =============================================================================

SYMBOL=BTCUSDT
LEVERAGE=10


# =============================================================================
#  [3] POSITION SIZING  ← proven maximum-CAGR configuration
#
#  EQUITY_PERCENT=0  →  falls back to RISK_PERCENT=8% (SL-distance based).
#  This is the configuration that produced $1k→$42k (+112%/yr) in 5yr backtest.
#
#  Why RISK_PERCENT beats EQUITY_PERCENT for BTC futures:
#    RISK_PERCENT=8% scales position size inversely with ATR, so every SL hit
#    always costs exactly 8% of balance regardless of current volatility.
#    EQUITY_PERCENT=35% uses fixed leverage; at ATR=3% a single SL costs ~16%.
# =============================================================================

EQUITY_PERCENT=0
RISK_PERCENT=8.0

# Fixed-dollar overrides (leave at 0 to use RISK_PERCENT compounding).
ORDER_BALANCE_USD=0.0
RISK_USD=0.0


# =============================================================================
#  [4] STRATEGY PARAMETERS  (proven 5yr all-pass configuration)
# =============================================================================

# SL / TP as ATR multiples.  4:1 RR → break-even at 20% win rate.
ATR_SL_MULTIPLIER=1.5
ATR_TP_MULTIPLIER=6.0

# Breakout window (WFO auto-tunes this every 30 days; this is the cold-start default).
BREAKOUT_PERIOD=14

# ADX filter: require trend strength ≥ 20 before entering.
ADX_MIN=20.0
ADX_PERIOD=14

# Trailing stop: move SL to break-even once price moves 1.5×ATR in our favour.
# Set to 0 to disable.
TRAIL_ACTIVATE_ATR=1.5
TRAIL_LOCK_ATR=0.0
TRAIL_STOP_ATR=0.0

# Entry quality filters (do not change without backtesting).
ATR_RATIO_MIN=1.15
EMA_SLOPE_MIN_PCT=0.15
VOL_RATIO_MIN=0.3
ATR_1H_PCT_MIN=0.05
ATR_1H_PCT_MAX=5.0


# =============================================================================
#  [5] DAILY CIRCUIT BREAKERS
# =============================================================================

# Stop taking new entries once daily PnL hits these levels.
# Both reset at UTC midnight.  Set to 0 to disable.
DAILY_PROFIT_TARGET_USD=110.0
DAILY_LOSS_LIMIT_USD=50.0

# Halt after N consecutive stop-losses in a row (resets UTC midnight).
MAX_CONSECUTIVE_LOSSES=3

# Wait N extra 1H bars before re-entering after a stop-loss (avoids whipsaw re-entry).
POST_SL_COOLDOWN_1H=3


# =============================================================================
#  [6] LIVE SAFETY GUARDS
# =============================================================================

# Skip new entries when |funding rate| exceeds 0.10%/8h (≈ 11% APR carry).
FUNDING_RATE_MAX=0.001

# Poll the exchange every 30s to detect SL/TP fills that arrive outside the WS feed.
# CRITICAL: without this the bot stalls after a remotely-executed SL/TP.
LIVE_POSITION_SYNC_SECS=30

# Heartbeat log every 15 min (even with no trade activity).
HEARTBEAT_INTERVAL=900

# Session filter: 0,0 = trade 24/7 (proven maximum-growth mode).
SESSION_FILTER_START_UTC=0
SESSION_FILTER_END_UTC=0

# Entry order type: false = market (immediate fill), true = maker limit (saves ~60% fee).
USE_LIMIT_ENTRY=false
LIMIT_ENTRY_TIMEOUT=45


# =============================================================================
#  [7] WALK-FORWARD OPTIMIZATION  (ON by default)
# =============================================================================

WFO_ENABLED=true
WFO_RETUNE_INTERVAL=720
WFO_TRAINING_WINDOW=2160
WFO_MIN_TRADES=4

# Dynamic lookback: shrink training window to 14 days when ATR spikes ≥ 2× mean.
# Allows faster regime adaptation at cold start or after a volatility shock.
WFO_FAST_ENABLED=true
WFO_FAST_TRAINING_WINDOW=336
WFO_FAST_ATR_MULT=2.0


# =============================================================================
#  [8] INDICATOR WARMUP
# =============================================================================

# Minimum bars before strategy activates.  EMA200 needs 200; ADX needs 28.
MIN_CANDLES_5M=60
MIN_CANDLES_1H=210

# Initial cooldown: suppress entries for first N 1H bars (WFO still trains).
# 0 = disabled (correct for live mode — warm_start already seeds 3,030 bars).
# Set to 48 for short < 1yr backtests where EMA200 is SMA-seeded.
INITIAL_COOLDOWN_BARS=0


# =============================================================================
#  [9] TELEGRAM NOTIFICATIONS  (fill in to get real-time alerts)
# =============================================================================

# Leave blank to disable.  See README §4 for setup instructions.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_LEVEL=INFO


# =============================================================================
#  [10] STATE PERSISTENCE
# =============================================================================

# SQLite state database.  In Docker this is overridden to /app/state/bot_state.db.
BOT_STATE_DB_PATH=bot_state.db


# =============================================================================
#  [11] AUTONOMOUS FEATURES  (all OFF = proven maximum-growth mode)
#
#  Audit result (May 2026, 5yr backtest):
#    REGIME_FORECAST_ENABLED  → −49pp CAGR
#    ADAPTIVE_REGIME_ENABLED  → −91pp CAGR
#    DYNAMIC_TP_ENABLED       → −66pp CAGR
#    VOL_SIZING_ENABLED       → −25pp CAGR (with −8pp MaxDD benefit)
# =============================================================================

REGIME_FORECAST_ENABLED=false
ADAPTIVE_REGIME_ENABLED=false
ADAPTIVE_TRAILING_ENABLED=false
DYNAMIC_TP_ENABLED=false
VOL_SIZING_ENABLED=false


# =============================================================================
#  [12] EXCHANGE PRECISION  (BTCUSDT — do not change)
# =============================================================================

MIN_ORDER_QTY=0.001
QTY_STEP=0.001
PRICE_TICK=0.10
