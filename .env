# ── Binance Futures API credentials ──────────────────────────────────────────
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# ── Trading mode ──────────────────────────────────────────────────────────────
# true = paper (dry run, safe to test), false = real money
PAPER_TRADING=true

# ── Maximum-growth config (proven 5yr backtest: $1k→$42k, CAGR +112%/yr) ────
# Risk 8% of balance per trade — scales with compounding growth.
RISK_PERCENT=8.0
LEVERAGE=10

# Symbol
SYMBOL=BTCUSDT

# ── Warm-up: bars required before strategy activates ──────────────────────────
MIN_CANDLES_5M=60
MIN_CANDLES_1H=210

# ── Live safety (uncomment to override defaults) ──────────────────────────────
# FUNDING_RATE_MAX=0.001       # skip entry when |funding| > 0.10%/8h
# MAX_CONSECUTIVE_LOSSES=3     # halt today after 3 SLs in a row
# POST_SL_COOLDOWN_1H=3        # wait 3 extra bars after SL before re-entering
# LIVE_POSITION_SYNC_SECS=30   # poll exchange every 30s for remote fills
# USE_LIMIT_ENTRY=false        # true = maker limit order (saves ~60% on fees)

# ── Optional: session time filter (0,0 = 24/7 — maximum growth) ──────────────
SESSION_FILTER_START_UTC=0
SESSION_FILTER_END_UTC=0

# ── Optional: fixed-dollar mode (turns off compounding) ──────────────────────
# ORDER_BALANCE_USD=0          # 0 = use RISK_PERCENT (recommended for growth)
# RISK_USD=0                   # 0 = use RISK_PERCENT
