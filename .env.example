# Binance Futures API credentials
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Trading mode: true = paper (dry run), false = live
PAPER_TRADING=true

# Risk per trade as % of account balance (e.g. 1 = 1%)
RISK_PERCENT=1.0

# Leverage (Binance Futures)
LEVERAGE=5

# Symbol to trade
SYMBOL=BTCUSDT

# Minimum candles required before strategy runs
MIN_CANDLES_5M=50
MIN_CANDLES_1H=50
