# =============================================================================
#  BTCUSDT Futures Trading Bot — Environment Configuration Template
#  Copy this file to .env and fill in your values before starting the bot.
#
#    cp .env.example .env
#    nano .env          # or: vim .env / code .env
#
#  SECURITY RULES
#  ──────────────
#  • NEVER commit .env to git.  It is already listed in .gitignore.
#  • Rotate API keys immediately if they are ever exposed.
#  • Use IP-whitelisted, Futures-only keys (no withdrawal permissions).
#  • On a server: chmod 600 .env  (owner read/write only)
# =============================================================================


# =============================================================================
#  [1] ENVIRONMENT
# =============================================================================

# Runtime environment.  Controls log verbosity and assertion guards.
# Values: production | staging | development
ENV=production

# Set to "false" to place real orders on Binance Futures.
# Set to "true" (default) to run in paper-trading simulation mode.
# PAPER_TRADING must be explicitly set to "false" before going live.
PAPER_TRADING=false


# =============================================================================
#  [2] BINANCE API CREDENTIALS  ⚠️ CRITICAL — keep secret
# =============================================================================
#
#  How to create a Futures-only API key on Binance:
#    1. Log in → Profile → API Management → Create API
#    2. Enable:  "Enable Futures" only
#    3. Disable: "Enable Withdrawals"  (never needed by a trading bot)
#    4. Restrict access to: your server IP address (whitelist)
#    5. Copy Key and Secret ONCE — the secret is never shown again.
#
BINANCE_API_KEY=PASTE_YOUR_API_KEY_HERE
BINANCE_API_SECRET=PASTE_YOUR_API_SECRET_HERE


# =============================================================================
#  [3] TELEGRAM NOTIFICATIONS  (optional but strongly recommended)
# =============================================================================
#
#  Sends real-time alerts for: trade opens/closes, daily P&L summaries,
#  circuit-breaker fires, WFO retunings, and critical errors.
#
#  Setup (2 minutes):
#    1. Open Telegram → search "@BotFather" → /newbot → follow prompts
#    2. Copy the Bot Token shown (format: 123456789:AAF...)
#    3. Start a chat with your bot, then open in a browser:
#         https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#    4. Send any message to the bot, refresh the URL → copy "chat" → "id"
#
#  Leave both blank to disable Telegram entirely.
#
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Minimum Python log level to forward to Telegram.
# Values: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Recommended: INFO  (trade events, daily summaries, errors)
TELEGRAM_ALERT_LEVEL=INFO


# =============================================================================
#  [4] TRADING PAIR & LEVERAGE
# =============================================================================

SYMBOL=BTCUSDT
LEVERAGE=10


# =============================================================================
#  [5] RISK & POSITION SIZING
#
#  Priority (highest → lowest):
#    1. ORDER_BALANCE_USD > 0  →  fixed notional margin per trade
#    2. RISK_PERCENT           →  percentage of current balance per trade
#
#  Recommended: RISK_PERCENT=8.0  (proven 5-year winning config — see README)
# =============================================================================

# Percentage of account balance risked per trade (scales with compounding).
# 8% at $1,000 balance + 1.5×ATR SL → ~$80 maximum loss per trade.
RISK_PERCENT=8.0

# Fixed USDT margin per order (0 = disabled, uses RISK_PERCENT instead).
# Example: ORDER_BALANCE_USD=100 + LEVERAGE=10 → $1,000 notional.
ORDER_BALANCE_USD=0.0


# =============================================================================
#  [6] DAILY CIRCUIT BREAKERS
#
#  Both limits are checked after every trade close.  When either fires,
#  the bot skips all new entries until UTC midnight reset.
# =============================================================================

# Halt after daily P&L reaches this profit (USDT).  0 = off.
DAILY_PROFIT_TARGET_USD=110.0

# Halt after daily P&L reaches this loss (USDT, as positive number).  0 = off.
DAILY_LOSS_LIMIT_USD=50.0

# Consecutive stop-loss circuit breaker.
# Halt for the rest of the day after N stop-losses in a row.
# Resets each UTC midnight.  0 = off.  Recommended: 3.
MAX_CONSECUTIVE_LOSSES=3

# Wait this many extra 1H bars before re-entering after a stop-loss.
# Avoids immediately re-entering the same whipsaw that just hit your SL.
# 0 = use normal 1-bar cooldown.  Recommended: 3.
POST_SL_COOLDOWN_1H=3


# =============================================================================
#  [7] LIVE SAFETY GUARDS
# =============================================================================

# Block new entries when |Binance funding rate| exceeds this threshold.
# 0.001 = 0.10%/8h ≈ ~11% annualised carry cost.  0 = off.
FUNDING_RATE_MAX=0.001

# Poll the exchange every N seconds for SL/TP fills outside the WS feed.
# CRITICAL — without this the bot stalls after a remotely-filled SL/TP.
# Recommended: 30
LIVE_POSITION_SYNC_SECS=30

# Session filter: only open new positions between [START, END) UTC hours.
# 0,0 = 24/7 trading (maximum-growth mode, proven in 5-year backtest).
# Example: 7,22 → trade London + New York overlap only.
SESSION_FILTER_START_UTC=0
SESSION_FILTER_END_UTC=0

# Log a heartbeat status line every N seconds (even with no trade activity).
HEARTBEAT_INTERVAL=900


# =============================================================================
#  [8] AUTONOMOUS EXECUTION MODE
#
#  Based on the 5-year backtest audit (May 2021 → May 2026):
#
#   Mode                    CAGR       MaxDD   5yr return   Verdict
#   ─────────────────────── ─────────  ──────  ──────────   ───────
#   Classic  (WFO=false)    +112%/yr   −49%    $1k→$42k     ✅ Maximum CAGR
#   WFO only (DEFAULT)      +101%/yr   −53%    $1k→$32k     ✅ RECOMMENDED DEFAULT
#   Forecast only           + 63%/yr   −50%    $1k→$11k     ⚠️  blocks entries
#   Adaptive TP/SL          + 21%/yr   −42%    $1k→ $2.5k   ❌ NOT RECOMMENDED
#   All features combined   + 15%/yr   −21%    $1k→  $2k    ❌ NOT RECOMMENDED
#
#  Default: WFO ON — automatic BREAKOUT_PERIOD self-tuning every 30 days.
#  Set WFO_ENABLED=false (or use --no-wfo) only for the pure classic static mode.
# =============================================================================

# Walk-Forward Optimization: auto-select BREAKOUT_PERIOD every 30 days.
# Re-tests 5 candidate periods (7/10/14/21/28 bars) over the last 90 days.
# DEFAULT: true — disable with WFO_ENABLED=false or the --no-wfo CLI flag.
WFO_ENABLED=true
WFO_RETUNE_INTERVAL=720
WFO_TRAINING_WINDOW=2160
WFO_MIN_TRADES=4

# Markov regime forecast: suppress entries when choppy regime is predicted.
# Hurts CAGR by ~49pp — disable for maximum growth.
REGIME_FORECAST_ENABLED=false

# Adaptive regime framework (Hurst + ADX + BBW → dynamic TP/SL/size).
# ❌ Hurts CAGR by ~91pp — keep false in production.
ADAPTIVE_REGIME_ENABLED=false

# Adaptive trailing stop (tightening funnel toward TP).
# ❌ Only effective alongside ADAPTIVE_REGIME_ENABLED — keep false.
ADAPTIVE_TRAILING_ENABLED=false


# =============================================================================
#  [9] DATABASE & STATE PERSISTENCE
# =============================================================================

# Path to the SQLite state database used by StateManager for crash recovery.
# Relative paths resolve from the project root.  Created automatically.
BOT_STATE_DB_PATH=bot_state.db


# =============================================================================
#  [10] OPTIONAL FINE-TUNING  (safe to leave at defaults)
# =============================================================================

# Binance BTCUSDT exchange precision rules (do not change unless symbol changes).
MIN_ORDER_QTY=0.001
QTY_STEP=0.001
PRICE_TICK=0.10

# Use maker limit-order entry instead of taker market order.
# Saves ~60% on entry commission (0.02% maker vs 0.05% taker).
# Falls back to market order if not filled within LIMIT_ENTRY_TIMEOUT seconds.
USE_LIMIT_ENTRY=false
LIMIT_ENTRY_TIMEOUT=45
