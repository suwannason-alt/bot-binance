# ─────────────────────────────────────────────────────────────────────────────
# XAUUSDT (Gold) perpetual — example .env  [AGGRESSIVE gold profile]
# ─────────────────────────────────────────────────────────────────────────────
# Copy to `.env` (or merge into your existing one) to trade gold instead of BTC.
#
# PRECISION — do NOT set MIN_ORDER_QTY / QTY_STEP / PRICE_TICK here.  Leaving them
# unset lets config.py's SYMBOL_PROFILES supply the correct gold values
# automatically (tick=0.01, lot=0.001, min-notional=$5).  If you pin them you
# override the profile and risk the BTC tick (0.10) rejecting every gold order.
#
# STRATEGY PARAMS — also NOT set here.  ATR_TP/SL_MULTIPLIER, ADX_MIN,
# ATR_RATIO_MIN and EMA_SLOPE_MIN_PCT are NOT read from .env by config.py; they
# are driven by the per-symbol SYMBOL_PROFILES["XAUUSDT"]["strategy"] block in
# config.py.  Setting them here has NO effect — edit the profile to change them.
# Active gold profile (aggressive): TP=8.0×ATR, SL=1.5×ATR, ADX≥25,
# ATR_RATIO_MIN=1.10, EMA_SLOPE_MIN_PCT=0.0.
#
# ⚠️ OVERFIT WARNING: these params were grid-searched on the only ~6 months of
# gold history — one continuous bull run ($4.2k→$5.6k), no bear / sustained chop.
# In-sample full-window WFO backtest: +48% / ~6 mo, PF 1.46, MaxDD −37%, 28 trades
# (vs the conservative default +39% / PF 2.10 / −18%).  Chosen for max absolute
# return + trade frequency at ~2× the drawdown.  PAPER-TRADE FIRST.  See README §4.

SYMBOL=XAUUSDT

# ── Sizing / risk (production model: RISK-constant, same as BTC) ─────────────
# EQUITY_PERCENT MUST be 0 to activate RISK_PERCENT mode — the repo documents
# RISK_PERCENT=8% as superior to EQUITY_PERCENT=35% (README §2). Any value > 0
# takes priority and disables risk-constant sizing.
EQUITY_PERCENT=0
RISK_PERCENT=8.0
LEVERAGE=10

# ── Walk-forward optimizer adapts BREAKOUT_PERIOD live ───────────────────────
WFO_ENABLED=true

# ── Daily circuit breakers / safeguards (intact; tune to your account size) ──
DAILY_PROFIT_TARGET_USD=110.0
DAILY_LOSS_LIMIT_USD=50.0
MAX_CONSECUTIVE_LOSSES=3

# ── Start in paper mode; flip to false only after live-testing the gold feed ──
PAPER_TRADING=true
# BINANCE_API_KEY=...
# BINANCE_API_SECRET=...
