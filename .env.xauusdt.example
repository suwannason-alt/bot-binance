# ═════════════════════════════════════════════════════════════════════════════
#  XAUUSDT (Gold) — PRODUCTION TEMPLATE  ·  CONSERVATIVE PROFILE  ·  wallet ≈ $92.04
# ═════════════════════════════════════════════════════════════════════════════
#  Copy to `.env` to deploy the gold setup.  Start in PAPER mode, verify the
#  pipeline, then flip PAPER_TRADING=false with real API keys.
#
#  Gold runs the CONSERVATIVE profile — identical to the proven BTC filters, the
#  best risk-adjusted config on the only ~6 months of gold history.  In-sample
#  full-window WFO backtest, production sizing: +39% / PF 2.10 / MaxDD −18% /
#  9 trades.  (An aggressive alt exists — +48% but PF 1.46 / MaxDD −37% / 28 trades,
#  overfit to the single bull run; see README §4.)  Still one bull regime with
#  n=9 — not a validated edge.  PAPER-TRADE FIRST.
# ─────────────────────────────────────────────────────────────────────────────

# ── 1. Core symbol ───────────────────────────────────────────────────────────
SYMBOL=XAUUSDT
# SYMBOL_CCXT is DERIVED in config.py (f"{SYMBOL[:3]}/{SYMBOL[3:]}") — it is NOT
# read from .env.  With SYMBOL=XAUUSDT it auto-resolves to XAU/USDT, so the CCXT
# futures integration is already correct; no env entry is needed (kept here as a
# reference note only):
#   SYMBOL_CCXT → XAU/USDT
# WS_URL is likewise auto-built from SYMBOL (NOT env-read) and routes the gold
# streams automatically:  xauusdt@kline_5m / @kline_1h / @markPrice / @aggTrade

# ── 2. Execution mode ────────────────────────────────────────────────────────
PAPER_TRADING=true
# BINANCE_API_KEY=PASTE_YOUR_KEY
# BINANCE_API_SECRET=PASTE_YOUR_SECRET

# ── 3. Exchange precision — INTENTIONALLY UNSET ──────────────────────────────
# Do NOT set PRICE_TICK / QTY_STEP / MIN_ORDER_QTY here.  Leaving them out lets
# config.py's SYMBOL_PROFILES["XAUUSDT"] supply the correct gold values:
#   PRICE_TICK=0.01   QTY_STEP=0.001   MIN_ORDER_QTY=0.001   MIN_NOTIONAL=$5
# Pinning the BTC tick (0.10) here would get every gold order rejected.

# ── 4. Strategy params — PROFILE-DRIVEN, NOT env ─────────────────────────────
# ATR_TP/SL_MULTIPLIER, ADX_MIN, ATR_RATIO_MIN, EMA_SLOPE_MIN_PCT are NOT read
# from .env — they come from SYMBOL_PROFILES["XAUUSDT"]["strategy"] in config.py.
# Setting them here has NO effect; edit the profile to change them.
# Active CONSERVATIVE gold matrix (= proven BTC filters):
#   ATR_TP_MULTIPLIER=6.0   ATR_SL_MULTIPLIER=1.5   ADX_MIN=20.0
#   ATR_RATIO_MIN=1.15      EMA_SLOPE_MIN_PCT=0.15

# ── 5. Position sizing  (production risk-constant model) ─────────────────────
# EQUITY_PERCENT=0 activates RISK_PERCENT mode → each SL costs exactly 8% of the
# wallet regardless of ATR.  At $92.04: risk/trade ≈ $7.36; the order is capped
# by LEVERAGE×balance ≈ $920 notional — far above the $5 MIN_NOTIONAL guard, so
# normal entries are never rejected (the guard only blocks sub-$5 dust orders).
EQUITY_PERCENT=0
RISK_PERCENT=8.0
LEVERAGE=10
RISK_USD=0.0
ORDER_BALANCE_USD=0.0

# ── 6. Circuit breakers ──────────────────────────────────────────────────────
# Primary small-account breaker (env-read, ACTIVE): halt the day after 3
# consecutive SLs (≈ −22% compounded at 8% risk).  At $92 this is the binding
# protection and triggers well before any daily-USD cap below.
MAX_CONSECUTIVE_LOSSES=3
POST_SL_COOLDOWN_1H=3
# ⚠️ NOTE: the daily P/L limits (DAILY_PROFIT_TARGET_USD=110, DAILY_LOSS_LIMIT_USD=50,
# and the _PCT variants) are HARDCODED in config.py — they are NOT read from .env,
# so setting them here does nothing.  At a $92 wallet they are effectively inert
# (the 3-consecutive-loss breaker, ≈ −$21, trips long before −$50), so this is
# safe as-is.  To actually scale them for a small account, edit config.py (ideally
# add them to SYMBOL_PROFILES["XAUUSDT"], the same pattern as the strategy params).

# ── 7. Network & reliability ─────────────────────────────────────────────────
# The WebSocket auto-reconnects on any error.  Resilience constants
# (ping_timeout=20s, reconnect_delay=5s) are hardcoded in ws_client.py — there is
# no .env watchdog field.  The env-tunable safety timers are below:
LIVE_POSITION_SYNC_SECS=30        # poll exchange every 30s to catch remote SL/TP fills (critical for live)
FUNDING_RATE_MAX=0.001            # skip entries above 0.10%/8h funding
HEARTBEAT_INTERVAL=900            # status line every 15 min when idle

# ── 8. Walk-forward optimizer (adapts BREAKOUT_PERIOD live) ──────────────────
WFO_ENABLED=true
